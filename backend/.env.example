PYTHON_PROCESSOR_URL=http://localhost:8090
AUDIO_TMP_DIR=./tmp
CACHE_DIR=./tmp/cache
MAX_CONCURRENT_JOBS=1
ALLOWED_ORIGINS=http://localhost:5173
PORT=8080
# 32+ random bytes used to HMAC-sign videoIds returned by /api/songs/search.
# Generate with: openssl rand -hex 32. Backend fails fast if missing or < 32 bytes.
VIDEO_ID_SIGNING_KEY=replace_with_openssl_rand_hex_32

# Storage backend. "local" uses CACHE_DIR + /internal/blob URL handoff.
# "r2" uses Cloudflare R2 with presigned URLs.
STORAGE_BACKEND=local
# Public base URL the Python service uses to hit /internal/blob in local mode.
BLOB_BASE_URL=http://localhost:8080

# R2 (only required when STORAGE_BACKEND=r2):
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=cantus-cache
# R2_PRESIGN_TTL_SECONDS=600

# Processor URLs — CPU_PROCESSOR_URL and GPU_PROCESSOR_URL are the canonical
# per-client names. Both default to PYTHON_PROCESSOR_URL when unset, so a
# single Python service handles all processor calls. Override independently
# when the Python service split plan routes CPU and GPU work to separate hosts.
# CPU_PROCESSOR_URL=
# GPU_PROCESSOR_URL=
CPU_PROCESSOR_TIMEOUT_SECONDS=30
GPU_PROCESSOR_TIMEOUT_SECONDS=180
