PYTHON_PROCESSOR_URL=http://localhost:8090
CACHE_DIR=./tmp/cache
MAX_CONCURRENT_JOBS=1
ALLOWED_ORIGINS=http://localhost:5173
PORT=8080
# 32+ random bytes used to HMAC-sign videoIds returned by /api/songs/search.
# Generate with: openssl rand -hex 32. Backend fails fast if missing or < 32 bytes.
VIDEO_ID_SIGNING_KEY=replace_with_openssl_rand_hex_32

# Storage backend. "local" uses CACHE_DIR + /internal/blob URL handoff.
# "r2" uses Cloudflare R2 with presigned URLs.
STORAGE_BACKEND=local
# Public base URL the Python service uses to hit /internal/blob in local mode.
BLOB_BASE_URL=http://localhost:8080

# R2 (only required when STORAGE_BACKEND=r2):
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=cantus-cache
# R2_PRESIGN_TTL_SECONDS=600

# Processor URL — points at the Python GPU service (BS-Roformer + CREPE).
# Defaults to PYTHON_PROCESSOR_URL when unset.
# In production: set to the Modal deploy URL printed by `modal deploy modal_app.py`.
# PROCESSOR_URL=
PROCESSOR_TIMEOUT_SECONDS=180

# Pitch-shift CLI binaries. Defaults resolve via $PATH.
# RUBBERBAND_PATH=rubberband
# FFMPEG_PATH=ffmpeg

# yt-dlp YouTube cookies file path. Empty = no cookies (local dev).
# In docker-compose this is overridden to /secrets/youtube-cookies.txt.
# YT_DLP_COOKIES_PATH=
